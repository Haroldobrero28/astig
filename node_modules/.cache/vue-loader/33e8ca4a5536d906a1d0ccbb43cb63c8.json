{"remainingRequest":"C:\\xampp\\htdocs\\astig\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\xampp\\htdocs\\astig\\src\\views\\Login.vue?vue&type=script&lang=js&","dependencies":[{"path":"C:\\xampp\\htdocs\\astig\\src\\views\\Login.vue","mtime":1616392613796},{"path":"C:\\xampp\\htdocs\\astig\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1615945445759},{"path":"C:\\xampp\\htdocs\\astig\\node_modules\\babel-loader\\lib\\index.js","mtime":1615945440846},{"path":"C:\\xampp\\htdocs\\astig\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1615945445759},{"path":"C:\\xampp\\htdocs\\astig\\node_modules\\vue-loader\\lib\\index.js","mtime":1615945482560}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Login.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA","file":"Login.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n  <div class=\"row\">\r\n    <div\r\n      class=\"col-12 col-sm-8 offset-sm-2 col-md-6 offset-md-3 mt-5 pt-3 pb-3 bg-white from-wrapper\"\r\n    >\r\n      <div class=\"container\">\r\n        <h3>Signin</h3>\r\n        <hr />\r\n\r\n        <form @submit.prevent=\"signin()\" action=\"/\" method=\"post\">\r\n          <div class=\"form-group\">\r\n            <label for=\"username\">Username</label>\r\n            <input\r\n              type=\"text\"\r\n              class=\"form-control\"\r\n              name=\"username\"\r\n              id=\"username\"\r\n              v-model=\"username\"\r\n            />\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label for=\"password\">Password</label>\r\n            <input\r\n              type=\"password\"\r\n              class=\"form-control\"\r\n              name=\"password\"\r\n              id=\"password\"\r\n              v-model=\"password\"\r\n            />\r\n          </div>\r\n          <alert v-if=\"msg\" :msg=\"msg\" :classAlert=\"classAlert\"></alert>\r\n          <div class=\"row\">\r\n            <div class=\"col-12 col-sm-4\">\r\n              <button type=\"submit\" class=\"btn btn-primary\">Login</button>\r\n            </div>\r\n            <div class=\"col-12 col-sm-8 text-right\">\r\n              <router-link to=\"/signup\">don't have an account</router-link>\r\n            </div>\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\n\r\nimport Alert from \"../cmps/Alert\";\r\nexport default { \r\n  data() {\r\n    return {\r\n      token: null,\r\n      expires_in: null,\r\n      username: \"\",\r\n      password: \"\",\r\n      msg: null,\r\n      Alert: null\r\n    }\r\n    \r\n  },\r\n\r\n  methods: {\r\n    signin() {\r\n      const auth = {\r\n        // passing the Basic Oauth ** client credential nasa (dapat meron kang .env dito sa\r\n        //vuejs dun nakaindicate yung icacall dito) * pass auth as third parameter ->*\r\n        username: process.env.VUE_APP_CLIENT_ID,\r\n        password: process.env.VUE_APP_CLIENT_SECRET,\r\n      };\r\n      const form = new FormData();\r\n\r\n      form.append(\"username\", this.username);\r\n      form.append(\"password\", this.password);\r\n      form.append(\"grant_type\", \"password\"); //the grant_type is Ewan pacomment nalang kung alam mo *default grant_type is 'password'\r\n\r\n      this.$guest\r\n        .post(\"/login\", form, { auth }) // <- *\r\n        .then((res) => {\r\n          this.msg = \"You have been successfully Logged in\";\r\n          this.classAlert = \"success\";\r\n          this.username = \"\";\r\n          this.password = \"\";\r\n\r\n          this.token = res.data.access_token; // etong dalawang to ay galing sa oauth access token para\r\n          this.expires_in = res.data.expires_in; // lang mag show sa response malaman naten na existing to, lam mo na :)\r\n          const expiresMs = this.expires_in * 1000;\r\n          const now = new Date();\r\n          const expireDate = new Date(now.getTime() + expiresMs);\r\n          localStorage.setItem(\"token\", this.token);\r\n          localStorage.setItem(\"expires\", expireDate);\r\n\r\n          //store dispatch\r\n          this.$store.dispatch(\"login\", expiresMs);\r\n        })\r\n        .catch((err) => {\r\n          this.msg = err.response.data.error_description;\r\n          this.classAlert = \"danger\";\r\n        });\r\n    },\r\n  },\r\n  components: {\r\n   \r\n    Alert,\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped></style>\r\n"]}]}