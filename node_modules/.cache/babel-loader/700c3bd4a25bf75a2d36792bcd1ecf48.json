                  <label for=\"username\">Username</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"username\"\r\n                    id=\"username\"\r\n                    v-model=\"username\"\r\n                    />\r\n                </div>\r\n                </div>\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"firstName\">First Name</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"firstName\"\r\n                    id=\"firstName\"\r\n                    v-model=\"firstName\"\r\n                    />\r\n                </div>\r\n                </div>\r\n\r\n                <!-- <div class=\"col-12 col-md-6\" >\r\n                <div class=\"form-group\">\r\n                    <label for=\"middlename\">Middle Name</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"middlename\"\r\n                    id=\"middlename\"\r\n                    v-model=\"middlename\"\r\n                    />\r\n                </div>\r\n                </div> -->\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"lastName\">Last Name</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"lastName\"\r\n                    id=\"lastName\"\r\n                    v-model=\"lastName\"\r\n                    />\r\n                </div>\r\n                </div>\r\n\r\n                <!-- <div class=\"col-5 col-sm-3\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"namepreffix\">Name Preffix</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"namepreffix\"\r\n                    id=\"namepreffix\"\r\n                    v-model=\"namepreffix\"\r\n                    />\r\n                </div>\r\n                </div> -->\r\n\r\n                <!-- <div class=\"col-5 col-sm-3\" >\r\n                <div class=\"form-group\">\r\n                    <label for=\"namesuffix\">Name Suffix</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"namesuffix\"\r\n                    id=\"namesuffix\"\r\n                    v-model=\"namesuffix\"\r\n                    />\r\n                </div>\r\n                </div> -->\r\n                \r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"emailAddress\">Email address</label>\r\n                    <input\r\n                    type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"emailAddress\"\r\n                    id=\"emailAddress\"\r\n                    v-model=\"emailAddress\"\r\n                    />\r\n                </div>\r\n                </div>\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"role\">Role</label>\r\n                    \r\n                    <select class=\"form-control\"\r\n                    name=\"role\"\r\n                    id=\"role\"\r\n                    v-model=\"role\">\r\n                      <option selected>Choose...</option>\r\n                      <option value=\"viewer\">Viewer</option>\r\n                      <option value=\"data_editor\">Data Editor</option>\r\n                    </select>\r\n                </div>\r\n                </div>\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"office\">office</label>\r\n                    <select class=\"form-control\"\r\n                    name=\"office\"\r\n                    id=\"office\"\r\n                    v-model=\"office\">\r\n                      <option selected>Choose...</option>\r\n                      <option value=\"One\">One</option>\r\n                      <option value=\"Two\">Two</option>\r\n                      <option value=\"Three\">Three</option>\r\n                    </select>\r\n                </div>\r\n                </div>\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"service\">Service</label>\r\n                    <select type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"service\"\r\n                    id=\"service\"\r\n                    v-model=\"service\">\r\n                      <option selected>Choose...</option>\r\n                      <option value=\"One\">One</option>\r\n                      <option value=\"Two\">Two</option>\r\n                      <option value=\"Three\">Three</option>\r\n                    </select>\r\n                </div>\r\n                </div>\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"division\">Division</label>\r\n                    <select type=\"text\"\r\n                    class=\"form-control\"\r\n                    name=\"division\"\r\n                    id=\"division\"\r\n                    v-model=\"division\">\r\n                      <option selected>Choose...</option>\r\n                      <option value=\"One\">One</option>\r\n                      <option value=\"Two\">Two</option>\r\n                      <option value=\"Three\">Three</option>\r\n                    </select>\r\n                </div>\r\n                </div>\r\n\r\n                \r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                <div class=\"form-group\">\r\n                    <label for=\"password\">Password</label>\r\n                    <input\r\n                    type=\"password\"\r\n                    class=\"form-control\"\r\n                    name=\"password\"\r\n                    id=\"password\"\r\n                    value=\"\"\r\n                    v-model=\"password\"\r\n                    />\r\n                </div>\r\n                </div>\r\n\r\n                <div class=\"col-12 col-md-6\">\r\n                    <div class=\"form-group\">\r\n                        <label for=\"password_confirm\">Confirm Password</label>\r\n                        <input\r\n                        type=\"password\"\r\n                        class=\"form-control\"\r\n                        name=\"password_confirm\"\r\n                        id=\"password_confirm\"\r\n                        value=\"\"\r\n                        v-model=\"password_confirm\"\r\n                        />\r\n                    </div>\r\n                </div>\r\n                <alert v-if=\"msg\" :msg=\"msg\" :classAlert=\"classAlert\"></alert>\r\n            </div>\r\n\r\n          <div class=\"row \">\r\n            <div class=\"mx-auto\">\r\n              <button type=\"submit\" class=\"btn btn-primary\">Register</button>\r\n            </div>\r\n            <!-- <div class=\"col-12 col-sm-10 text-right\">\r\n              <router-link to=\"/login\">Already have an account</router-link>\r\n            </div> -->\r\n          </div>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Alert from \"../cmps/Alert\";\r\nexport default {\r\n  data() {\r\n    return {\r\n      //idnumber: \"\",\r\n      username: \"\",\r\n      firstName: \"\",\r\n      //middlename: \"\",\r\n      lastName: \"\",\r\n      //namepreffix: \"\",\r\n      //namesuffix: \"\",\r\n      emailAddress: \"\",\r\n      role : \"\",\r\n      office: \"\",\r\n      service: \"\",\r\n      division: \"\",\r\n      password: \"\",\r\n      password_confirm: \"\",\r\n      msg: null,\r\n      classAlert: null,\r\n    };\r\n  },\r\n  /* mounted: {\r\n    getOffice() {\r\n      this.$api.get(\"/office/getOffice\").then((result)=>{\r\n        console.log(result);\r\n      })\r\n      .catch(err => {\r\n        console.log(err);\r\n      });\r\n    },\r\n  }, */\r\n  methods: {\r\n    register() {\r\n      const form = new FormData();\r\n      //form.append(\"idnumber\", this.idnumber);\r\n      form.append(\"username\", this.username);\r\n      form.append(\"firstName\", this.firstName);\r\n      //form.append(\"middlename\", this.middlename);\r\n      form.append(\"lastName\", this.lastName);\r\n      //form.append(\"namepreffix\", this.namepreffix);\r\n      //form.append(\"namesuffix\", this.namesuffix);\r\n      form.append(\"emailAddress\", this.emailAddress);\r\n      form.append(\"role\", this.role);\r\n      form.append(\"office\", this.office);\r\n      form.append(\"service\", this.service);\r\n      form.append(\"division\", this.division);\r\n      form.append(\"password\", this.password);\r\n      form.append(\"password_confirm\", this.password_confirm);\r\n\r\n      this.$guest.post(\"/register\", form)\r\n      .then(() => {\r\n        this.msg = 'You have been successfully registered';\r\n        this.classAlert = \"success\";\r\n        \r\n        //this.idnumber= \"\";\r\n        this.username=\"\";\r\n        this.firstName= \"\";\r\n        //this.middlename= \"\";\r\n        this.lastName= \"\";\r\n        //this.namepreffix= \"\";\r\n        //this.namesuffix= \"\";\r\n        this.emailAddress= \"\";\r\n        this.role=\"\";\r\n        this.office= \"\";\r\n        this.service= \"\";\r\n        this.division= \"\";\r\n        this.password= \"\";\r\n      })\r\n      .catch(err => {\r\n        this.msg = err.response.data.messages.error;\r\n        this.classAlert = \"danger\";\r\n      });\r\n    //axios\r\n    },\r\n  },\r\n  components: {\r\n    Alert,\r\n  },\r\n};\r\n</script>\r\n\r\n<style>\r\n\r\n\r\n</style>\r\n"],"sourceRoot":"src/views"}]}